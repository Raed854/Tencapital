# Railway Environment Configuration
# Production Environment Variables

# Railway automatically sets PORT
PORT=80

# API Configuration for Railway
# Change this to your actual backend URL when available
REACT_APP_API_URL=https://ton-frontend.up.railway.app/api
REACT_APP_API_TIMEOUT=10000
# Optional: Comma-separated list of fallback URLs (leave empty if not needed)
REACT_APP_FALLBACK_URLS=https://ton-frontend.up.railway.app/api

# Railway Public URL
REACT_APP_PUBLIC_URL=https://ton-frontend.up.railway.app

# Environment
NODE_ENV=production

# Authentication Configuration
REACT_APP_JWT_SECRET=your-jwt-secret-key-for-production
REACT_APP_TOKEN_EXPIRY=24h

# Feature Flags
REACT_APP_ENABLE_ANALYTICS=true
REACT_APP_ENABLE_DEBUG=false

# Chart.js Configuration
REACT_APP_CHART_DEFAULT_COLOR=#3b82f6
REACT_APP_CHART_BACKGROUND_COLOR=rgba(59, 130, 246, 0.1)

# File Upload Configuration
REACT_APP_MAX_FILE_SIZE=10485760
REACT_APP_ALLOWED_FILE_TYPES=.xlsx,.xls,.csv

# Security Configuration
REACT_APP_CORS_ORIGIN=https://ton-frontend.up.railway.app
REACT_APP_SECURE_COOKIES=true

# Performance Configuration
REACT_APP_LAZY_LOADING=true
REACT_APP_CODE_SPLITTING=true
