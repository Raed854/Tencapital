# .env.local - Personal local overrides (optional)
# This file is for personal local development overrides
# It takes precedence over .env
# DO NOT commit this file to version control

# Example: Use a different API URL for your local setup
# REACT_APP_API_URL=http://localhost:8080

# Example: Enable debug mode
# REACT_APP_ENABLE_DEBUG=true

# Example: Use a different backend
# REACT_APP_API_URL=https://staging-api.example.com
